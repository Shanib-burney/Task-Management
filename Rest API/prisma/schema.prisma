generator client {
 provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  role         Int      @db.SmallInt
  status       Int      @db.SmallInt
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  status    Int      @db.SmallInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}